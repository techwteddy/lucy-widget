DATABASE_URL=postgresql+asyncpg://chatbot:chatbot@localhost:5432/chatbot_widget
REDIS_URL=redis://localhost:6379/0
ANTHROPIC_API_KEY=sk-ant-...
ADMIN_KEY=change-me-in-production
SECRET_KEY=change-me-in-production
ENVIRONMENT=development

# Gemini embedding (required for RAG)
GEMINI_API_KEY=your-gemini-api-key

# Demo mode (enables demo login and demo chatbot)
DEMO_MODE=false

# Supabase auth (required for user-facing dashboard)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# Stripe billing (required for paid plans)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_BUSINESS_PRICE_ID=price_...
